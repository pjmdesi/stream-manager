{
    "name": "stream-manager",
    "version": "1.5.0",
    "description": "A streaming file management app for Twitch/YouTube streamers",
    "main": "./out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "start": "electron .",
        "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
        "dist": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json && electron-vite build && electron-builder",
        "release:patch": "npm version patch && npm run dist",
        "release:minor": "npm version minor && npm run dist",
        "release:major": "npm version major && npm run dist"
    },
    "build": {
        "appId": "com.streammanager",
        "productName": "Stream Manager",
        "files": [
            "out/**/*"
        ],
        "win": {
            "icon": "resources/icon.png",
            "target": [
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "mac": {
            "icon": "resources/icon.png",
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ]
        },
        "linux": {
            "icon": "resources/icon.png",
            "target": [
                {
                    "target": "AppImage",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "asarUnpack": [
            "node_modules/ffmpeg-static/**/*",
            "node_modules/ffprobe-static/**/*"
        ],
        "extraResources": [
            {
                "from": "resources/icon.png",
                "to": "icon.png"
            }
        ]
    },
    "dependencies": {
        "chokidar": "^3.6.0",
        "electron-store": "^8.2.0",
        "ffmpeg-static": "^5.2.0",
        "ffprobe-static": "^3.1.0",
        "fluent-ffmpeg": "^2.1.3",
        "glob": "^10.3.10",
        "konva": "^10.2.5",
        "micromatch": "^4.0.5",
        "motion": "^12.38.0",
        "react-konva": "^18.2.14",
        "use-image": "^1.1.4",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "@types/fluent-ffmpeg": "^2.1.24",
        "@types/micromatch": "^4.0.6",
        "@types/node": "^20.11.0",
        "@types/react": "^18.2.48",
        "@types/react-dom": "^18.2.18",
        "@types/uuid": "^9.0.7",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.17",
        "electron": "^34.0.0",
        "electron-builder": "^26.0.0",
        "electron-vite": "^2.3.0",
        "lucide-react": "^0.312.0",
        "postcss": "^8.4.33",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.3.3",
        "vite": "^5.0.12"
    }
}
